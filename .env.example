# OpenKB ローカル実行用 環境変数テンプレート
# このファイルをコピーして .env にリネームし、値を入力してください
# cp .env.example .env

# ── 方法A: 直接 API キーを使う（ローカル開発向け） ──────────────────
# Anthropic Console → API Keys で発行
LLM_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── 方法B: WIF（GitHub Actions 専用 / ローカルでは使用不可） ────────
# GitHub Actions のワークフロー内では Secrets から自動注入されるため不要
# ANTHROPIC_FEDERATION_RULE_ID=fdrl_xxxxxxxx
# ANTHROPIC_ORGANIZATION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ANTHROPIC_SERVICE_ACCOUNT_ID=svac_xxxxxxxx
